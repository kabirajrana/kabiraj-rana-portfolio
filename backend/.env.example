# Required
APP_ENV=production
PORT=8000
ALLOWED_ORIGINS=https://kabirajrana.com.np,https://www.kabirajrana.com.np,https://admin.kabirajrana.com.np,http://localhost:3000
MAIL_PROVIDER=resend
RESEND_API_KEY=re_replace_with_real_key
RESEND_FROM=contact@kabirajrana.com.np
RESEND_TO=kabirajrana76@gmail.com

# Optional (only needed if MAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=replace_with_smtp_username
SMTP_PASS=replace_with_smtp_password
SMTP_FROM=contact@kabirajrana.com.np
SMTP_TO=kabirajrana76@gmail.com

# Optional tuning
CONTACT_RATE_LIMIT=5
CONTACT_RATE_WINDOW_SEC=60

# PostgreSQL (required for persistent credentials)
DATABASE_URL=postgresql://username:password@host:5432/database

# Optional one-time seed of 2 default credentials when credentials table is empty
CREDENTIALS_SEED_ON_EMPTY=false

# Legacy fallback for CORS if ALLOWED_ORIGINS is not set
FRONTEND_ORIGIN=http://localhost:3000
