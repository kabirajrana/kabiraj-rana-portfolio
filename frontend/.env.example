NEXT_PUBLIC_API_URL=https://api.example.com
# Client-side API base used by the public website and frontend browser code.
# Required in Vercel production for public API calls and contact forms.
# If you only set BACKEND_API_URL, this repo will also accept it as a fallback.
# Prefer setting both NEXT_PUBLIC_API_URL and BACKEND_API_URL to the same backend origin.
# Use backend origin (preferred): https://kabiraj-rana-portfolio-production.up.railway.app or your Render service URL.
# A base with /v1 also works, but avoid duplicating path segments manually elsewhere.
BACKEND_API_URL=https://api.example.com
GITHUB_USERNAME=kabirajrana
# Required for production GitHub dashboard/contributions accuracy.
# Set in frontend/.env locally and in Vercel Project Settings -> Environment Variables.
GITHUB_TOKEN=github_pat_xxx_replace_with_your_token

ADMIN_JWT_SECRET=replace_with_strong_random_secret
ADMIN_SESSION_COOKIE=admin_session
ADMIN_SESSION_TTL_SECONDS=604800
ADMIN_PREVIEW_COOKIE=admin_preview
ADMIN_PREVIEW_SECRET=replace_with_preview_secret
# Required for admin seed flow: these become your admin login credentials.
# You can use either ADMIN_SEED_* or ADMIN_LOGIN_* (both are supported).
# To keep the same login on local and production admin panels, use the same
# values here and in Railway backend environment variables.
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=replace_with_strong_password
ADMIN_ALLOW_SEED_LOGIN=false
ADMIN_ALLOW_OFFLINE_DATA=false
# Optional aliases for deployment dashboards/secrets managers.
ADMIN_LOGIN_EMAIL=admin@example.com
ADMIN_LOGIN_PASSWORD=replace_with_strong_password

UPLOAD_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=

NEXT_PUBLIC_SITE_URL=https://www.example.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
